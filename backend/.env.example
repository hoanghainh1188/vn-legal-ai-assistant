# Cấu hình backend — biến môi trường (prefix VN_LEGAL_). Sao chép thành .env.
# KHÔNG commit .env thật; KHÔNG hardcode secret.

# --- Ollama (embedding self-host bge-m3; chat qwen3.5 ở cấu hình mặc định) ---
VN_LEGAL_OLLAMA_BASE_URL=http://localhost:11434
VN_LEGAL_EMBED_MODEL=bge-m3
VN_LEGAL_LLM_MODEL=qwen3.5

# --- Kho vector: Postgres của Supabase local (Pha 2) ---
# Lấy DB URL từ output `supabase start` (project này dùng dải cổng 544xx → DB ở 54422).
VN_LEGAL_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres
VN_LEGAL_RETRIEVAL_TOP_K=8
VN_LEGAL_VECTOR_POOL=30

# --- Nhà cung cấp AI (hybrid) ---
VN_LEGAL_CHAT_PROVIDER=ollama          # ollama | claude
VN_LEGAL_EMBEDDING_PROVIDER=ollama     # ollama
# Chỉ cần khi CHAT_PROVIDER=claude — lấy từ nơi quản lý secret, KHÔNG commit:
# VN_LEGAL_CLAUDE_API_KEY=
VN_LEGAL_CLAUDE_MODEL=claude-sonnet-4-6
VN_LEGAL_CLAUDE_TIMEOUT=300.0
VN_LEGAL_CLAUDE_MAX_TOKENS=4096

# --- Khác ---
VN_LEGAL_FRONTEND_ORIGIN=http://localhost:3000
