# --- Ollama (self-host) ---
VN_LEGAL_OLLAMA_BASE_URL=http://localhost:11434
VN_LEGAL_EMBED_MODEL=bge-m3
VN_LEGAL_LLM_MODEL=qwen3.5

# --- ChromaDB / retrieval ---
VN_LEGAL_CHROMA_PERSIST_DIR=./chroma_data
VN_LEGAL_COLLECTION_NAME=vn_housing_law
VN_LEGAL_RETRIEVAL_TOP_K=8
VN_LEGAL_MAX_EMBED_CHARS=8000

# --- Provider selection (hybrid AI) ---
# chat: ollama | claude   |   embedding: ollama
VN_LEGAL_CHAT_PROVIDER=ollama
VN_LEGAL_EMBEDDING_PROVIDER=ollama

# --- Claude (chỉ cần khi CHAT_PROVIDER=claude) ---
# KHÔNG commit key thật. Đặt qua biến môi trường / secret manager.
VN_LEGAL_CLAUDE_API_KEY=
VN_LEGAL_CLAUDE_MODEL=claude-sonnet-4-6
VN_LEGAL_CLAUDE_TIMEOUT=300.0
VN_LEGAL_CLAUDE_MAX_TOKENS=4096

# --- CORS ---
VN_LEGAL_FRONTEND_ORIGIN=http://localhost:3000
