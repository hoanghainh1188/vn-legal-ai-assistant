# Frontend env — sao chép thành .env.local. KHÔNG commit .env.local.
# Giá trị lấy từ output `supabase start` (project này dùng dải cổng 544xx).
# Chỉ dùng ANON key ở frontend — TUYỆT ĐỐI không đưa service_role vào đây.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key từ `supabase start`>
